{
  "name": "tasks-app",
  "private": true,
  "version": "1.0.5",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "node scripts/verify-release-notes.mjs && node scripts/build-release-notes.mjs && electron-vite build",
    "preview": "electron-vite preview",
    "build:mcp": "vite build --config vite.mcp.config.ts",
    "build:mcpb": "bash scripts/build-mcpb.sh",
    "dev:mcp": "node out/mcp/run.cjs",
    "dev:web": "vite --config vite.preview.config.ts",
    "verify:release-notes": "node scripts/verify-release-notes.mjs",
    "build:release-notes": "node scripts/build-release-notes.mjs",
    "dist": "node scripts/verify-release-notes.mjs && node scripts/build-release-notes.mjs && electron-vite build && electron-builder --mac",
    "release": "node scripts/verify-release-notes.mjs && node scripts/build-release-notes.mjs && electron-vite build && electron-builder --mac --publish always"
  },
  "build": {
    "appId": "com.tasks-app.desktop",
    "productName": "Tasks",
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "icon": "resources/icon.icns",
      "sign": false,
      "preAutoEntitlements": false
    },
    "dmg": {
      "title": "Tasks",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "!out/mcp/**"
    ],
    "extraResources": [
      {
        "from": "out/mcp",
        "to": "mcp",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "mcp-deps/node_modules",
        "to": "mcp-deps/node_modules",
        "filter": [
          "better-sqlite3/**/*",
          "bindings/**/*",
          "file-uri-to-path/**/*"
        ]
      }
    ],
    "npmRebuild": true,
    "publish": {
      "provider": "github",
      "owner": "arne-braeckman",
      "repo": "tasks-app"
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.45.1",
    "electron-updater": "^6.8.3",
    "nanoid": "^5.1.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^5.0.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.1"
  }
}
