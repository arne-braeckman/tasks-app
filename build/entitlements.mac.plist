<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Basic app entitlements -->
  <key>com.apple.security.app-sandbox</key>
  <true/>

  <!-- Allow execution of code needed for auto-updates -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>

  <!-- File system access for updates -->
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>

  <!-- Network access for auto-updates and MCP -->
  <key>com.apple.security.network.client</key>
  <true/>
  <key>com.apple.security.network.server</key>
  <true/>

  <!-- IPC communication -->
  <key>com.apple.security.device.ipc</key>
  <true/>

  <!-- Allow subprocess execution (needed for MCP server) -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>

  <!-- Camera/Microphone (if needed in future) -->
  <key>com.apple.security.device.camera</key>
  <false/>
  <key>com.apple.security.device.microphone</key>
  <false/>
</dict>
</plist>
