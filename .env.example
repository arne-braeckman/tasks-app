# Code Signing Configuration
# Required for macOS app signing and auto-updates

# Apple Developer Certificate Identity
# Example: "Developer ID Application: Your Name (XXXXXXXXXX)"
CSC_NAME=

# Certificate password (if using .p12 file)
# Used to decrypt the certificate
CSC_KEY_PASSWORD=

# Apple Team ID
# 10-character code from developer.apple.com
# Example: "XXXXXXXXXX"
APPLE_TEAM_ID=

# (Optional) Apple ID for notarization
# Required for macOS 10.15+
APPLE_ID=

# (Optional) App-specific password for notarization
# Generate at appleid.apple.com
APPLE_APP_SPECIFIC_PASSWORD=

# GitHub Personal Access Token
# Required for publishing releases
# Scope: public_repo
GH_TOKEN=

# Auto Discovery (set to false to disable auto code signing)
# CSC_IDENTITY_AUTO_DISCOVERY=false

# Debug (uncomment for verbose output)
# DEBUG=electron-builder
